// Firestore security rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isProjectMember(projectId) {
      let proj = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isSignedIn() && proj != null && (
        request.auth.uid == proj.ownerUid ||
        request.auth.uid in proj.memberUids
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read: if isProjectMember(projectId);

      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;

      // Owner can update anything
      // Members can update only nicknames and avatars
      // Non-members can join ONLY by adding their own UID (invite acceptance)
      //   — must not remove existing members, must only add self
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerUid ||
        (request.auth.uid in resource.data.memberUids &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['nicknames', 'avatars', 'updatedAt'])) ||
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['memberUids', 'memberEmails', 'nicknames', 'updatedAt']) &&
         request.auth.uid in request.resource.data.memberUids &&
         request.resource.data.memberUids.hasAll(resource.data.memberUids))
      );

      allow delete: if false;

      match /tasks/{taskId} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if isProjectMember(projectId);
      }
    }

    match /invites/{inviteId} {
      allow read: if isSignedIn() && request.auth.token.email == resource.data.toEmail;

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && isProjectMember(request.resource.data.projectId);

      allow update: if isSignedIn()
        && request.auth.token.email == resource.data.toEmail;

      allow delete: if false;
    }
  }
}
